        {
            "parameters": {
                "jsCode": "// Enrich VIDEO posts for the meme pipeline\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const data = item.json;\n  const hasVideo = data.is_video === true || (data.video_url && data.video_url.trim() !== '');\n  if (!hasVideo) continue;\n  \n  const videoUrl = (data.video_url && data.video_url.trim()) || data.url || '';\n  let subreddit = data.subreddit || data.source || '';\n  if (!subreddit && data.url) {\n    const match = data.url.match(/r\\/([^/]+)/);\n    if (match) subreddit = match[1];\n  }\n  \n  results.push({\n    json: {\n      id: data.id || `meme_${Date.now()}_${Math.random().toString(36).substr(2, 6)}`,\n      title: data.title || '',\n      url: data.url || '',\n      video_url: videoUrl,\n      image_url: '',\n      content_type: 'video',\n      source: 'reddit',\n      subreddit: subreddit,\n      upvotes: data.upvotes || data.score || 0,\n      flair: data.flair || '',\n      download_status: 'pending',\n      queued_at: new Date().toISOString()\n    }\n  });\n}\n\nconsole.log(`Enriched ${results.length} video clips`);\nreturn results.length > 0 ? results : [{ json: { error: 'No video posts found' } }];"
            },
