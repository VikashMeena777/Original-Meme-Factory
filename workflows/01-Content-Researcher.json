        {
            "parameters": {
                "jsCode": "// Merge all Reddit API responses from 5 parallel fetch nodes into one array\nconst items = $input.all();\nconst allPosts = [];\n\nfor (const item of items) {\n  const data = item.json;\n  \n  // Each fetch returns an array of posts\n  if (Array.isArray(data)) {\n    for (const post of data) {\n      allPosts.push({ json: post });\n    }\n  } else if (data.data && Array.isArray(data.data)) {\n    for (const post of data.data) {\n      allPosts.push({ json: post });\n    }\n  } else if (data.id) {\n    // Already individual items from n8n auto-split\n    allPosts.push({ json: data });\n  }\n}\n\nconsole.log(`Merged ${allPosts.length} posts from all subreddit groups`);\nreturn allPosts.length > 0 ? allPosts : [{ json: { error: 'no posts found' } }];"
            },
